{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}
  ],
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "tags": ["quantum", "ML", "VQE", "observability"],
  "templating": {
    "list": [
      {"name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "current": {}, "hide": 0},
      {"name": "tier", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": "label_values(qp_batch_total, tier)", "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "hide": 0, "refresh": 2, "multi": false, "sort": 1},
      {"name": "lane", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": "label_values(qp_batch_done, lane)", "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "hide": 0, "refresh": 2, "multi": false, "sort": 1},
      {"name": "optimizer", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": "label_values(qp_vqe_total_time, optimizer)", "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "hide": 0, "refresh": 2, "multi": true, "sort": 1},
      {"name": "molecule", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": "label_values(qp_vqe_total_time, molecule_symbols)", "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "hide": 0, "refresh": 2, "multi": true, "sort": 1},
      {"name": "container_type", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "query": "label_values(qp_vqe_total_time, container_type)", "includeAll": true, "allValue": ".*", "current": {"text": "All", "value": "$__all"}, "hide": 0, "refresh": 2, "multi": true, "sort": 1}
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Quantum Pipeline",
  "uid": null,
  "version": 1,
  "panels": [
    {"type": "row", "id": 1, "title": "Batch Generation", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "panels": []},
    {
      "id": 2, "type": "gauge", "title": "Progress", "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 80, "color": "green"}]}}},
      "targets": [{"expr": "sum(qp_batch_done{tier=~\"$tier\"}) / sum(qp_batch_total{tier=~\"$tier\"}) * 100", "legendFormat": ""}]
    },
    {
      "id": 3, "type": "stat", "title": "Done", "gridPos": {"h": 6, "w": 3, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}]}}},
      "targets": [{"expr": "sum(qp_batch_done{tier=~\"$tier\"})", "legendFormat": "done"}]
    },
    {
      "id": 4, "type": "stat", "title": "Failed", "gridPos": {"h": 6, "w": 3, "x": 9, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 10, "color": "red"}]}}},
      "targets": [{"expr": "sum(qp_batch_failed{tier=~\"$tier\"})", "legendFormat": "failed"}]
    },
    {
      "id": 5, "type": "stat", "title": "Pending", "gridPos": {"h": 6, "w": 3, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "blue"}]}}},
      "targets": [{"expr": "sum(qp_batch_pending{tier=~\"$tier\"})", "legendFormat": "pending"}]
    },
    {
      "id": 6, "type": "bargauge", "title": "Per-Lane Progress", "gridPos": {"h": 6, "w": 9, "x": 15, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}]}}},
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "targets": [{"expr": "qp_batch_done{tier=~\"$tier\",lane=~\"$lane\"}", "legendFormat": "{{lane}}"}]
    },
    {
      "id": 7, "type": "timeseries", "title": "Throughput (runs/hour)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10}}},
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [{"expr": "increase(qp_batch_done{tier=~\"$tier\",lane=~\"$lane\"}[10m]) * 6", "legendFormat": "{{lane}}"}]
    },
    {
      "id": 8, "type": "timeseries", "title": "Failed Over Time", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10}, "color": {"fixedColor": "red", "mode": "fixed"}}},
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [{"expr": "qp_batch_failed{tier=~\"$tier\",lane=~\"$lane\"}", "legendFormat": "{{lane}}"}]
    },

    {"type": "row", "id": 10, "title": "VQE Performance", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}, "panels": [
      {
        "id": 11, "type": "timeseries", "title": "VQE Total Time", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "fillOpacity": 10}}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_total_time{optimizer=~\"$optimizer\",molecule_symbols=~\"$molecule\",container_type=~\"$container_type\"}", "legendFormat": "{{molecule_symbols}} / {{optimizer}}"}]
      },
      {
        "id": 12, "type": "timeseries", "title": "Iterations per Second", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_iterations_per_second{optimizer=~\"$optimizer\",molecule_symbols=~\"$molecule\",container_type=~\"$container_type\"}", "legendFormat": "{{molecule_symbols}} / {{container_type}}"}]
      },
      {
        "id": 13, "type": "gauge", "title": "VQE Efficiency", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 16},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 0.5, "color": "yellow"}, {"value": 0.8, "color": "green"}]}}},
        "targets": [{"expr": "avg(qp_vqe_efficiency{container_type=~\"$container_type\"})"}]
      },
      {
        "id": 14, "type": "gauge", "title": "Overhead Ratio", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 16},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.5, "color": "yellow"}, {"value": 1, "color": "red"}]}}},
        "targets": [{"expr": "avg(qp_vqe_overhead_ratio{container_type=~\"$container_type\"})"}]
      },
      {
        "id": 15, "type": "timeseries", "title": "Iteration Count", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_iterations_count{optimizer=~\"$optimizer\",molecule_symbols=~\"$molecule\"}", "legendFormat": "{{molecule_symbols}} / {{optimizer}}"}]
      },
      {
        "id": 16, "type": "timeseries", "title": "Time per Iteration", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "s"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_time_per_iteration{optimizer=~\"$optimizer\",molecule_symbols=~\"$molecule\"}", "legendFormat": "{{molecule_symbols}}"}]
      },
      {
        "id": 17, "type": "timeseries", "title": "Setup Ratio", "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percentunit"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_setup_ratio{container_type=~\"$container_type\"}", "legendFormat": "{{container_type}}"}]
      }
    ]},

    {"type": "row", "id": 20, "title": "Scientific Accuracy", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16}, "panels": [
      {
        "id": 21, "type": "timeseries", "title": "Energy Error (mHa)", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 17},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_energy_error_millihartree{molecule_symbols=~\"$molecule\",optimizer=~\"$optimizer\"}", "legendFormat": "{{molecule_symbols}} / {{optimizer}}"}]
      },
      {
        "id": 22, "type": "bargauge", "title": "Accuracy Score", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 17},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 90, "color": "green"}]}}},
        "options": {"orientation": "horizontal", "displayMode": "gradient"},
        "targets": [{"expr": "qp_vqe_accuracy_score{molecule_symbols=~\"$molecule\",optimizer=~\"$optimizer\"}", "legendFormat": "{{molecule_symbols}} / {{optimizer}}"}]
      },
      {
        "id": 23, "type": "stat", "title": "Chemical Accuracy", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 17},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 50, "color": "yellow"}, {"value": 80, "color": "green"}]}}},
        "targets": [{"expr": "avg(qp_vqe_within_chemical_accuracy{molecule_symbols=~\"$molecule\"}) * 100"}]
      },
      {
        "id": 24, "type": "timeseries", "title": "Ground State Energy", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "Hartree"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_minimum_energy{molecule_symbols=~\"$molecule\",optimizer=~\"$optimizer\"}", "legendFormat": "{{molecule_symbols}} / {{optimizer}}"}]
      },
      {
        "id": 25, "type": "timeseries", "title": "Reference Energy", "gridPos": {"h": 8, "w": 8, "x": 12, "y": 25},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_vqe_reference_energy{molecule_symbols=~\"$molecule\"}", "legendFormat": "{{molecule_symbols}} ref"}]
      }
    ]},

    {"type": "row", "id": 30, "title": "System Resources", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17}, "panels": [
      {
        "id": 31, "type": "timeseries", "title": "CPU Usage", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}, "custom": {"drawStyle": "line", "fillOpacity": 10, "thresholdsStyle": {"mode": "line"}}}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_sys_cpu_percent{container_type=~\"$container_type\"}", "legendFormat": "{{container_type}}"}]
      },
      {
        "id": 32, "type": "timeseries", "title": "Memory Usage", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 18},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 85, "color": "yellow"}, {"value": 95, "color": "red"}]}, "custom": {"drawStyle": "line", "fillOpacity": 10, "thresholdsStyle": {"mode": "line"}}}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "qp_sys_memory_percent{container_type=~\"$container_type\"}", "legendFormat": "{{container_type}}"}]
      },
      {
        "id": 33, "type": "stat", "title": "Uptime", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 18},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "dtdurations"}},
        "targets": [{"expr": "qp_sys_uptime_seconds{container_type=~\"$container_type\"}", "legendFormat": "{{container_type}}"}]
      },
      {
        "id": 34, "type": "stat", "title": "Load Average (1m)", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 18},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "qp_sys_cpu_load_1m{container_type=~\"$container_type\"}", "legendFormat": "{{container_type}}"}]
      }
    ]},

    {"type": "row", "id": 40, "title": "GPU", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}, "panels": [
      {
        "id": 41, "type": "timeseries", "title": "GPU Utilization", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "nvidia_gpu_utilization_gpu_ratio * 100", "legendFormat": "GPU {{index}}"}],
        "noDataMessage": "Requires nvidia_gpu_exporter"
      },
      {
        "id": 42, "type": "timeseries", "title": "GPU Temperature", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "celsius", "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 85, "color": "red"}]}, "custom": {"thresholdsStyle": {"mode": "line"}}}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "nvidia_gpu_temperature_celsius", "legendFormat": "GPU {{index}}"}],
        "noDataMessage": "Requires nvidia_gpu_exporter"
      },
      {
        "id": 43, "type": "bargauge", "title": "GPU Memory", "gridPos": {"h": 8, "w": 4, "x": 16, "y": 19},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
        "options": {"orientation": "horizontal"},
        "targets": [{"expr": "nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes * 100", "legendFormat": "GPU {{index}}"}],
        "noDataMessage": "Requires nvidia_gpu_exporter"
      },
      {
        "id": 44, "type": "timeseries", "title": "GPU Power", "gridPos": {"h": 8, "w": 4, "x": 20, "y": 19},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "watt"}},
        "targets": [{"expr": "nvidia_gpu_power_draw_watts", "legendFormat": "GPU {{index}}"}],
        "noDataMessage": "Requires nvidia_gpu_exporter"
      }
    ]},

    {"type": "row", "id": 50, "title": "Data Platform", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19}, "panels": [
      {
        "id": 51, "type": "timeseries", "title": "Kafka Messages In/sec", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "rate(kafka_server_brokertopicmetrics_messagesin_total[5m])", "legendFormat": "messages/s"}],
        "noDataMessage": "Requires Kafka JMX exporter"
      },
      {
        "id": 52, "type": "timeseries", "title": "Kafka Bytes In/sec", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "Bps"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "rate(kafka_server_brokertopicmetrics_bytesin_total[5m])", "legendFormat": "bytes/s"}],
        "noDataMessage": "Requires Kafka JMX exporter"
      },
      {
        "id": 53, "type": "timeseries", "title": "Redpanda Connect Throughput", "gridPos": {"h": 8, "w": 8, "x": 16, "y": 20},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "rate(input_received_total[5m])", "legendFormat": "msgs/s"}],
        "noDataMessage": "Requires Redpanda Connect port 4195"
      },
      {
        "id": 54, "type": "stat", "title": "Redpanda Errors/sec", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 0.1, "color": "red"}]}}},
        "targets": [{"expr": "rate(output_error_total[5m])"}],
        "noDataMessage": "Waiting for data..."
      },
      {
        "id": 55, "type": "stat", "title": "Spark Workers", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "spark_master_workers_count"}],
        "noDataMessage": "Requires Spark Prometheus metrics"
      },
      {
        "id": 56, "type": "timeseries", "title": "Garage Request Rate", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "rate(garage_api_request_total[5m])", "legendFormat": "req/s"}],
        "noDataMessage": "Requires Garage admin API"
      }
    ]},

    {"type": "row", "id": 60, "title": "Orchestration", "collapsed": true, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20}, "panels": [
      {
        "id": 61, "type": "timeseries", "title": "Airflow DAG Run Duration", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 21},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "s"}},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "airflow_dagrun_duration_sum", "legendFormat": "{{dag_id}}"}],
        "noDataMessage": "Requires Airflow StatsD exporter"
      },
      {
        "id": 62, "type": "stat", "title": "Scheduler Heartbeat", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 21},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "airflow_scheduler_heartbeat"}],
        "noDataMessage": "Requires Airflow StatsD exporter"
      },
      {
        "id": 63, "type": "timeseries", "title": "Postgres Connections", "gridPos": {"h": 8, "w": 6, "x": 12, "y": 21},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "options": {"tooltip": {"mode": "multi"}},
        "targets": [{"expr": "pg_stat_database_numbackends", "legendFormat": "{{datname}}"}],
        "noDataMessage": "Requires postgres-exporter"
      },
      {
        "id": 64, "type": "gauge", "title": "Postgres Cache Hit Ratio", "gridPos": {"h": 4, "w": 6, "x": 18, "y": 21},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "red"}, {"value": 0.9, "color": "yellow"}, {"value": 0.95, "color": "green"}]}}},
        "targets": [{"expr": "pg_stat_database_blks_hit / (pg_stat_database_blks_hit + pg_stat_database_blks_read)"}],
        "noDataMessage": "Requires postgres-exporter"
      },
      {
        "id": 65, "type": "timeseries", "title": "Redis Memory", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 29},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "fieldConfig": {"defaults": {"unit": "bytes"}},
        "targets": [{"expr": "redis_memory_used_bytes"}],
        "noDataMessage": "Requires redis-exporter"
      },
      {
        "id": 66, "type": "stat", "title": "Redis Ops/sec", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 29},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "rate(redis_commands_processed_total[5m])"}],
        "noDataMessage": "Requires redis-exporter"
      },
      {
        "id": 67, "type": "stat", "title": "Redis Clients", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 29},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "redis_connected_clients"}],
        "noDataMessage": "Requires redis-exporter"
      }
    ]}
  ]
}
