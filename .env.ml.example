# Quantum Pipeline ML Stack
# Copy to .env and customize, or run: just ml-setup

# --- pipeline ---
LOG_LEVEL=INFO
SIMULATION_METHOD=statevector

# --- kafka ---
KAFKA_VERSION=4.2.0
KAFKA_SERVERS=kafka:9092
KAFKA_EXTERNAL_HOST_IP=localhost
KAFKA_EXTERNAL_PORT=9094
KAFKA_INTERNAL_PORT=9092
KAFKA_NODE_ID=1

SCHEMA_REGISTRY_VERSION=8.2.0
SCHEMA_REGISTRY_TOPIC=_schemas
SCHEMA_REGISTRY_HOSTNAME=schema-registry
SCHEMA_REGISTRY_PORT=8081

KAFKA_CONNECT_VERSION=8.2.0
KAFKA_CONNECT_PORT=8083
KAFKA_CONNECT_LOG_LEVEL=INFO

# --- garage (s3-compatible storage) ---
GARAGE_VERSION=v2.2.0
GARAGE_S3_API_PORT=3901
GARAGE_RPC_PORT=3900
GARAGE_ADMIN_PORT=3903
GARAGE_WEB_PORT=3902

# generated by just ml-setup - do not edit manually
GARAGE_RPC_SECRET=CHANGE_ME_32_BYTE_HEX
GARAGE_ADMIN_TOKEN=CHANGE_ME_32_BYTE_HEX

# generated by just ml-setup after first start
S3_ACCESS_KEY=GK_CHANGE_ME
S3_SECRET_KEY=CHANGE_ME_TO_64_CHAR_HEX_SECRET
S3_REGION=garage
S3_ENDPOINT=http://garage:3901

S3_RAW_BUCKET=local-vqe-results
S3_FEATURES_BUCKET=local-features
S3_ICEBERG_BUCKET=iceberg

# --- spark ---
SPARK_VERSION=3.5.8
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
SPARK_DEFAULT_QUEUE=default

# --- airflow ---
AIRFLOW_VERSION=2.10.5
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow-password
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_FERNET_KEY=your-fernet-key-here
AIRFLOW_WEBSERVER_SECRET_KEY=your-webserver-secret-here
AIRFLOW_WEBSERVER_PORT=8084
AIRFLOW_DAGS_PAUSED_AT_CREATION=True
AIRFLOW_LOAD_EXAMPLES=False
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
POSTGRES_VERSION=16-alpine

# --- r2 sync (cloudflare) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=vqe-data
